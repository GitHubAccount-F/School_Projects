# Simple .gitignore file for CSE 333 24sp.
# Files matching these patterns should not normally be added to repos.

# Note: Unless you _really_ know what you're doing, please leave this
# file as-is and do not change it.  Modifications that don't work as
# expected might prevent files that should be pushed to your
# repository from being stored there, causing projects to fail when
# they are cloned or copied for testing or evaluation.

# Compiler output
*.o
*.so
*.a

# but always keep the *.a and other files found in solution-binaries
!**/solution_binaries/*

# also keep everything in libhw[1-4], including .a library links
!**/libhw[1-4]/*

# also keep everything in gtest, including libgtest.a
!**/gtest/*

# emacs backup files
*~

# OS X finder files (doesn't happen on linux, but sometimes useful)
.DS_Store


# Node.js dependencies
/node_modules/

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Java build files
*.class
*.jar
*.war
*.ear

# Visual Studio Code workspace settings
.vscode/

# MacOS system files
.DS_Store

# Windows system files
Thumbs.db
Desktop.ini

# Log files
*.log

# Environment variables (add your own .env file if used)
.env

# npm packages
package-lock.json

# .idea folder (JetBrains IDEs like IntelliJ, WebStorm)
.idea/

# Coverage folder (code coverage tools)
coverage/

# Testing (e.g., Jest, Mocha)
*.test.js
*.spec.js

# Build output (e.g., from Webpack, Grunt, etc.)
/dist/
/build/

# Docker
*.docker

# GitHub Actions workflows output
*.yml

# JavaScript / TypeScript
*.js.map
*.ts.map

# General IDE settings (e.g., IntelliJ, Sublime Text)
*.iml
.idea/

# User-specific files
*.swp
*~
